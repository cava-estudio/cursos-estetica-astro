++ ---
import MainLayout from '../../layouts/MainLayout.astro';

export async function getStaticProps() {
  const ENDPOINT = 'https://pago.cursosdeestetica.cl/graphql';
  let products = [];
  try {
    const res = await fetch(ENDPOINT, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        query: `query AllProducts { products(first: 100, where: {status: \"publish\"}) { nodes { name slug description shortDescription image { sourceUrl altText } } } }`,
      }),
    });
    const data = await res.json();
    products = data?.data?.products?.nodes ?? [];
  } catch (err) {
    console.error('Error fetching products for /productos:', err);
    products = [];
  }
  return { props: { products } };
}

const { products } = Astro.props;
---

<MainLayout title="Productos">
  <section style="max-width:1200px;margin:2.6rem auto;padding:18px;">
    <header style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:18px;">
      <div>
        <p class="eyebrow">Cursos</p>
        <h1 style="margin:6px 0 0 0;">Nuestros cursos</h1>
        <p style="color:var(--muted);max-width:60ch;margin-top:8px;">Listado básico de cursos migrados. Haz click en cualquier tarjeta para ver detalles.</p>
      </div>
    </header>

    {products && products.length ? (
      <div class="grid">
        {products.map((p) => (
          <a class="card" href={`/producto/${p.slug}`}> 
            <div class="media">{p.image?.sourceUrl ? <img src={p.image.sourceUrl} alt={p.image.altText ?? p.name} /> : <div style="height:140px;background:#f2f2f6;border-radius:8px;"></div>}</div>
            <h3>{p.name}</h3>
            <p class="muted">{p.shortDescription ? p.shortDescription.replace(/(<([^>]+)>)/gi, '').slice(0, 120) : ''}</p>
          </a>
        ))}
      </div>
    ) : (
      <p>No hay productos disponibles para mostrar.</p>
    )}
  </section>

  <style>
    .grid { display:grid; gap:18px; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); }
    .card { text-decoration:none; color:var(--text); background:var(--surface); padding:12px; border-radius:12px; box-shadow:var(--shadow); display:block; }
    .card h3 { margin:12px 0 6px 0; font-size:1.05rem; }
    .card .muted { color:var(--muted); font-size:.95rem; margin:0; }
    .media img { width:100%; height:140px; object-fit:cover; border-radius:8px; }
    @media (max-width:760px) { .grid { grid-template-columns: 1fr 1fr; } }
  </style>
</MainLayout>
