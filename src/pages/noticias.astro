---
import MainLayout from "../layouts/MainLayout.astro";

const noticias = [
  {
    fecha: "10 Ene 2024",
    titulo: "Tendencias 2024: ¿Por que la Criolipolisis sigue siendo el tratamiento estrella?",
    resumen:
      "Analisis de rentabilidad, demanda y efectividad de la criolipolisis frente a otros metodos de reduccion corporal.",
    href: "https://cursosdeestetica.cl/noticias/",
  },
  {
    fecha: "24 Ene 2024",
    titulo: "HIFU y MFUS: La ciencia detras del rejuvenecimiento sin cirugia",
    resumen:
      "Explicacion tecnica simplificada sobre como los ultrasonidos focalizados elevan resultados faciales sin tiempo de inactividad.",
    href: "https://cursosdeestetica.cl/noticias/",
  },
  {
    fecha: "07 Feb 2024",
    titulo: "Protocolos de seguridad: como evitar errores comunes en grasa localizada",
    resumen:
      "Buenas practicas de evaluacion y prevencion para reducir complicaciones y asegurar tratamientos responsables.",
    href: "https://cursosdeestetica.cl/noticias/",
  },
];
---

<MainLayout title="Noticias | Cursos de Estetica">
  <section class="news-page pt-32">
    <header class="news-header section">
      <p class="news-kicker">Noticias</p>
      <h1>Actualidad y Tendencias en Estética</h1>
      <p>
        Contenido editorial para profesionales que buscan actualizar criterios
        técnicos, optimizar resultados y fortalecer su posicionamiento.
      </p>
    </header>

    <section class="news-grid" aria-label="Grid de noticias">
      {noticias.map((item) => (
        <article class="news-card section">
          <img src="/noticias.jpg" alt={item.titulo} loading="lazy" />
          <div class="news-card-body">
            <time>{item.fecha}</time>
            <h2>{item.titulo}</h2>
            <p>{item.resumen}</p>
            <a href={item.href} class="news-btn">Leer mas</a>
          </div>
        </article>
      ))}
    </section>
  </section>
</MainLayout>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap");

  .pt-32 {
    padding-top: 8rem;
  }

  .news-page {
    display: grid;
    gap: 22px;
  }

  .news-header {
    padding: 30px clamp(16px, 3vw, 34px);
    border: 1px solid #e7ddff;
    background:
      radial-gradient(circle at 90% 20%, rgba(112, 79, 230, 0.18), transparent 42%),
      #faf8ff;
    font-family: "Plus Jakarta Sans", "Quicksand", sans-serif;
  }

  .news-kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
    color: #6f4ce4;
    font-weight: 700;
  }

  .news-header h1 {
    margin: 10px 0 0;
    font-size: clamp(1.6rem, 3.2vw, 2.5rem);
    line-height: 1.16;
    color: #2a2637;
  }

  .news-header p {
    margin: 12px 0 0;
    max-width: 66ch;
    color: #58556d;
    line-height: 1.65;
  }

  .news-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .news-card {
    overflow: hidden;
    border-radius: 18px;
    border: 1px solid #ece7f8;
    box-shadow: 0 10px 22px rgba(34, 22, 74, 0.08);
    background: #ffffff;
  }

  .news-card img {
    width: 100%;
    height: 210px;
    object-fit: cover;
    display: block;
  }

  .news-card-body {
    padding: 16px;
    display: grid;
    gap: 10px;
    font-family: "Plus Jakarta Sans", "Quicksand", sans-serif;
  }

  .news-card time {
    color: #7a7594;
    font-size: 0.82rem;
    font-weight: 600;
  }

  .news-card h2 {
    margin: 0;
    font-size: 1.16rem;
    line-height: 1.35;
    color: #27223a;
  }

  .news-card p {
    margin: 0;
    color: #5d5975;
    line-height: 1.52;
    min-height: 70px;
  }

  .news-btn {
    margin-top: 4px;
    width: fit-content;
    text-decoration: none;
    border-radius: 999px;
    background: #704fe6;
    color: #fff;
    min-height: 38px;
    padding: 9px 14px;
    font-weight: 700;
    font-size: 0.92rem;
  }

  @media (max-width: 1200px) {
    .news-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 860px) {
    .pt-32 {
      padding-top: 6rem;
    }

    .news-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
