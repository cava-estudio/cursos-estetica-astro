---
import MainLayout from '../layouts/MainLayout.astro';

export async function getStaticProps() {
  const ENDPOINT = 'https://cursosdeestetica.cl/graphql';
  let page = null;
  try {
    const res = await fetch(ENDPOINT, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        query: `query PageBySlug($slug: ID!) { page(id: $slug, idType: SLUG) { id databaseId slug title content } }`,
        variables: { slug: 'contacto' },
      }),
    });
    const data = await res.json();
    page = data?.data?.page ?? null;
  } catch (err) {
    console.error('Error fetching contacto page:', err);
    page = null;
  }
  return { props: { page } };
}

const { page } = Astro.props;
// Optional: set PUBLIC_WP_CONTACT_ENDPOINT in your environment to enable real posts
const CONTACT_ENDPOINT = import.meta.env.PUBLIC_WP_CONTACT_ENDPOINT ?? '';
---

<MainLayout title={page?.title ?? 'Contacto'}>
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  <section class="contact-section" style="max-width:1100px;margin:2.6rem auto;padding:18px;display:grid;gap:18px;">
    <header style="display:flex;flex-direction:column;gap:8px;">
      <p class="eyebrow" style="margin:0;color:var(--primary);text-transform:uppercase;font-weight:700;letter-spacing:.12em;">Contacto</p>
      <h1 style="margin:0;color: var(--title);font-size:clamp(1.6rem,3.4vw,2.6rem);">{page?.title ?? 'Contáctanos'}</h1>
      <p style="color:var(--muted);max-width:70ch;">Si tienes dudas sobre cursos, formaciones o quieres solicitar información personalizada, escríbenos usando el formulario o contacta directamente por teléfono o e‑mail.</p>
    </header>



    <!-- Two-column area: form (left) + contact aside (right) -->
    <div class="contact-grid" style="display:grid;grid-template-columns:1fr 420px;gap:26px;align-items:start;margin-top:18px;max-width:1100px;">
      <div>
        <form id="contact-form" style="display:grid;gap:12px;max-width:860px;" data-endpoint={CONTACT_ENDPOINT}>
          <input type="text" name="hp" id="hp" class="hp" aria-hidden="true" tabindex="-1" />
          <!-- Turnstile widget invisible -->
          <div class="cf-turnstile" 
               data-sitekey="0x4AAAAAAC_XXXXX_tEXcW2i"
               data-theme="light"
               data-size="invisible">
          </div>

          <div class="two-cols" style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <label for="name" style="display:block"><span class="sr-only">Nombre completo</span>
              <input id="name" name="name" type="text" placeholder="Nombre completo" required style="padding:10px;border-radius:10px;border:1px solid var(--line);width:100%;" />
            </label>

            <label for="phone" style="display:block"><span class="sr-only">Teléfono</span>
              <input id="phone" name="phone" type="tel" placeholder="Teléfono (opcional)" style="padding:10px;border-radius:10px;border:1px solid var(--line);width:100%;" />
            </label>
          </div>

          <label for="email" style="display:block"><span class="sr-only">Correo electrónico</span>
            <input id="email" name="email" type="email" placeholder="Correo electrónico" required style="padding:10px;border-radius:10px;border:1px solid var(--line);width:100%;" />
          </label>

          <label for="subject" style="display:block"><span class="sr-only">Asunto</span>
            <input id="subject" name="subject" type="text" placeholder="Asunto" style="padding:10px;border-radius:10px;border:1px solid var(--line);width:100%;" />
          </label>

          <label for="message" style="display:block"><span class="sr-only">Mensaje</span>
            <textarea id="message" name="message" rows="6" placeholder="Escribe tu mensaje" required style="padding:12px;border-radius:10px;border:1px solid var(--line);min-height:140px;width:100%;"></textarea>
          </label>

          <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;">
            <button id="submit-btn" type="submit" class="btn btn-primary" style="padding:10px 18px;border-radius:12px;">Enviar mensaje</button>
            <div id="form-status" class="sr-only" role="status" aria-live="polite"></div>
            <!-- Endpoint notice removed from UI -->
          </div>
        </form>
      </div>

      <aside class="contact-aside" style="border-radius:12px;padding:18px;">
        <div style="display:grid;gap:12px;align-items:start;">
          <div style="display:flex;gap:12px;align-items:center;">
            <div class="footer-mini-logo" style="display:flex;align-items:center;">
            </div>
    
          </div>

          <div class="footer-contact-list contact-hero" style="display:flex;flex-direction:column;gap:12px;margin-top:0;padding:0;">
            <a href="tel:+56944839131" class="footer-contact-item" style="align-items:center;gap:12px;padding:12px 14px;width:100%;box-sizing:border-box;">
              <span class="footer-contact-icon" aria-hidden="true">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.86 19.86 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.86 19.86 0 0 1 2.09 4.18 2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.72c.12.97.36 1.91.72 2.79a2 2 0 0 1-.45 2.11L9.91 9.91a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.11-.45c.88.36 1.82.6 2.79.72A2 2 0 0 1 22 16.92z" fill="white"></path>
                </svg>
              </span>
              <div class="contact-content">
                <span class="contact-main">+56 9 4483 9131</span>
                <span class="contact-sub">Llámanos</span>
              </div>
            </a>

            <a href="mailto:hola@cursosdeestetica.cl" class="footer-contact-item" style="align-items:center;gap:12px;padding:12px 14px;width:100%;box-sizing:border-box;">
              <span class="footer-contact-icon" aria-hidden="true">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M4 4h16v16H4z" fill="none"></path>
                  <path d="M22 6.5V18a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6.5" stroke="white" stroke-width="0" fill="white" />
                  <path d="M22 6.5l-10 7L2 6.5" fill="white"></path>
                </svg>
              </span>
              <div class="contact-content">
                <span class="contact-main">hola@cursosdeestetica.cl</span>
                <span class="contact-sub">Escríbenos</span>
              </div>
            </a>

            <a href="https://wa.me/56944839131" class="footer-contact-item" style="align-items:center;gap:12px;padding:12px 14px;width:100%;box-sizing:border-box;" target="_blank" rel="noopener noreferrer">
              <span class="footer-contact-icon" aria-hidden="true">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M20.52 3.48A11.92 11.92 0 0 0 12 1C6.48 1 2 5.48 2 11c0 1.89.5 3.66 1.38 5.2L2 23l6.02-1.36A11.92 11.92 0 0 0 12 23c5.52 0 10-4.48 10-10 0-1.92-.52-3.7-1.48-5.12zM12 20a8.94 8.94 0 0 1-4.54-1.2l-.32-.18-3.58.8.8-3.5-.2-.34A8.94 8.94 0 0 1 4 11c0-4.97 4.03-9 9-9 2.4 0 4.63.93 6.32 2.6A8.94 8.94 0 0 1 21 11c0 4.97-4.03 9-9 9z" fill="white"></path>
                  <path d="M17.6 14.2c-.3-.15-1.78-.88-2.06-.98-.28-.1-.48-.15-.68.15-.2.3-.78.98-.96 1.18-.18.2-.36.22-.66.07-.3-.15-1.26-.46-2.4-1.48-.89-.78-1.48-1.74-1.65-2.04-.17-.3-.02-.46.12-.6.12-.12.28-.3.42-.45.14-.15.18-.26.3-.43.12-.18.06-.33-.03-.48-.09-.15-.68-1.64-.93-2.25-.24-.6-.49-.52-.66-.53-.17-.01-.36-.01-.55-.01-.18 0-.48.07-.73.34-.25.27-.96.94-.96 2.3 0 1.36.98 2.68 1.12 2.87.14.18 1.94 3.04 4.7 4.26 3.26 1.48 3.26 1.01 3.84.95.58-.06 1.78-.72 2.03-1.42.25-.7.25-1.3.18-1.42-.07-.12-.28-.18-.58-.33z" fill="white"></path>
                </svg>
              </span>
              <div class="contact-content">
                <span class="contact-main">+56 9 4483 9131</span>
                <span class="contact-sub">WhatsApp</span>
              </div>
            </a>
      </aside>
    </div>
  </section>

   <script type="module">
  const form = document.getElementById('contact-form');
  const status = document.getElementById('form-status');
  const submitBtn = document.getElementById('submit-btn');

  // Sanitización básica anti-XSS
  function sanitize(str) {
    const temp = document.createElement('div');
    temp.textContent = str;
    return temp.innerHTML;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Estado de carga
    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando...';
    status.textContent = '';

    // Honeypot anti-spam
    const hp = form.querySelector('#hp');
    if (hp && hp.value) {
      // Bot detectado - simular éxito pero no enviar. Mostrar mensaje y redirigir a /gracias
      await new Promise(r => setTimeout(r, 800));
      status.style.color = 'green';
      status.textContent = '✓ Mensaje enviado correctamente.';
      const eparam = encodeURIComponent(form.email?.value || '');
      // Delay 4s to allow user to see confirmation before redirect
      setTimeout(() => { location.href = `/gracias${eparam ? `?email=${eparam}` : ''}`; }, 4000);
      return;
    }

    // Preparar datos
    const formData = new FormData();
    formData.append('access_key', 'e12f6cda-bbc0-470c-8588-6146478593ce');
    // Obtener token Turnstile
    const turnstileToken = form.querySelector('[name="cf-turnstile-response"]')?.value;
    if (turnstileToken) {
      formData.append('turnstile', turnstileToken);
    }
    formData.append('name', sanitize(form.name.value));
    formData.append('email', sanitize(form.email.value));
    formData.append('phone', sanitize(form.phone.value || ''));
    formData.append('subject', sanitize(form.subject.value || 'Contacto desde web'));
    formData.append('message', sanitize(form.message.value));
    
    // Metadata útil
    formData.append('from_name', 'Cursos de Estética');
    formData.append('replyto', form.email.value);

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: formData
      });

      const data = await response.json();

      if (data.success) {
        status.style.color = 'green';
        // Show only the short confirmation message
        status.textContent = '✓ Mensaje enviado correctamente.';
        const eparam = encodeURIComponent(form.email?.value || '');
        // Delay 4s to allow user to see confirmation before redirect
        setTimeout(() => { location.href = `/gracias${eparam ? `?email=${eparam}` : ''}`; }, 4000);
        form.reset();
      } else {
        throw new Error(data.message || 'Error desconocido');
      }

    } catch (err) {
      status.style.color = '#c00';
      status.textContent = '✗ Error al enviar. Por favor intenta nuevamente o contáctanos por teléfono.';
      console.error('Error:', err);
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Enviar mensaje';
    }
  });
</script>

  <style>
    .eyebrow { font-weight:700; color:var(--primary); text-transform:uppercase; letter-spacing:.12em; }
    .page-copy p { color:var(--text); line-height:1.7; }
    .sr-only { position:absolute;left:-10000px;top:auto;width:1px;height:1px;overflow:hidden; }
    .hp { position:absolute;left:-10000px;top:auto;width:1px;height:1px;overflow:hidden; }
    /* replicate footer contact visual style */
    /* Layout each contact item as two columns: fixed icon (left) + flexible content (right)
       this forces the icon to stay flush left and content to align consistently. */
    /* Make icon column fixed and align icon to the left edge of the card */
    .footer-contact-list { display:flex; flex-direction:column; gap:12px; align-items:stretch; padding:0; margin:0; }
    .footer-contact-item { display:grid; grid-template-columns: 56px 1fr; gap:12px; align-items:center; justify-items:start; text-decoration:none; color:var(--text); background: #fff; border-radius:12px; box-shadow: 0 6px 18px rgba(15,11,32,0.06); padding: 12px 14px; width:100%; box-sizing:border-box; }
    .footer-contact-icon { width:56px; height:56px; border-radius:12px; display:inline-flex; align-items:center; justify-content:center; background:linear-gradient(180deg,var(--primary),var(--primary-2)); color:#fff; font-weight:800; font-size:1.25rem; flex-shrink:0; justify-self:start; }
    .contact-hero .footer-contact-item { padding:12px 14px; border-radius:12px; }
    .contact-content { display:flex; flex-direction:column; align-items:flex-start; padding-right:8px; text-align:left; }
    /* Primary text size adjusted and line-height improved for readability */
    .contact-main { display:block; font-weight:700; font-size:0.95rem; line-height:1.22; text-align:left; overflow-wrap:break-word; word-break:break-word; max-width:100%; }
    .contact-sub { display:block; font-size:0.82rem; color:var(--muted); margin-top:6px; }
    .contact-grid { align-items:start; grid-template-columns: 1fr 420px; gap: 26px; }
    /* Move the aside higher and tighten internal spacing on desktop */
    .contact-aside { position:sticky; top:24px; padding-top:6px; }
    .contact-aside .footer-mini-logo { margin-bottom:6px; }
    .contact-aside h3 { margin:0 0 6px 0; text-align:left; }
    .contact-aside .contact-hero { margin-top:2px; }
    .contact-aside .footer-contact-list { gap:10px; }

    /* Responsive: collapse to single column on smaller screens and remove sticky aside */
    @media (max-width: 900px) {
      .contact-grid { grid-template-columns: 1fr !important; gap: 16px; }
      .contact-aside { position: static; top: auto; padding: 12px; }
      .contact-aside .footer-contact-item { padding: 12px 10px; }
      .footer-contact-icon { width:44px;height:44px;font-size:1.05rem; }
      form#contact-form { max-width: 100%; }
      /* Stack the two-column row on small screens */
      .two-cols { grid-template-columns: 1fr !important; }
      /* ensure inputs scale properly on narrow screens */
      form#contact-form input, form#contact-form textarea { width: 100% !important; box-sizing: border-box; }
      .contact-aside { margin-top: 0; }
    }

    /* Additional fine-tuning for very small screens */
    @media (max-width: 480px) {
      .contact-grid { gap: 12px !important; padding: 0 8px; }
      .eyebrow { font-size: 0.68rem; }
      h1 { font-size: 1.25rem; }
      .contact-aside .footer-contact-item { padding: 10px 8px; }
      .footer-contact-icon { width:36px; height:36px; font-size:0.9rem; justify-self:start; }
      .footer-contact-list { gap:12px; }
      .footer-contact-item { padding-left: 10px; padding-right: 10px; }
      .contact-main { font-size:0.92rem; }
      .footer-contact-item { padding-right: 12px; }
      .contact-main { font-size:0.85rem !important; }
      .menu-pill { font-size: 0.88rem; }
      .nav-cta { min-height: 40px; }
      .menu { gap: 8px; }
    }

    /* Fix para emails largos en pantallas muy estrechas (p.ej. 320px) */
    @media (max-width: 340px) {
      .footer-contact-item { grid-template-columns: 44px 1fr; padding: 8px 10px; gap:10px; }
      .footer-contact-icon { width:32px; height:32px; }
      .contact-main { font-size: 0.85rem; line-height:1.18; white-space:normal; overflow-wrap:anywhere; word-break:break-word; }
      .contact-sub { font-size:0.78rem; }
      .contact-content { padding-right:6px; }
      .contact-aside { padding-right: 8px; }
    }

    /* Prevent accidental horizontal overflow and ensure proper centering on mobile */
    .contact-section { box-sizing: border-box; padding-left: 12px; padding-right: 12px; 
      margin-left: auto; margin-right: auto; width: 100%; }
    .contact-grid { margin-inline: auto; width: 100%; box-sizing: border-box; }
    .contact-section * { max-width: 100%; box-sizing: border-box; }
    .contact-aside { max-width: 420px; width: 100%; box-sizing: border-box; padding-right: 12px; }
    .footer-contact-list { padding-right: 12px; }
    .contact-aside .footer-contact-list { gap:10px; }

    /* Ensure nav toggle stays above potential content shifts */
    .nav-toggle { z-index: 90; }
    /* Force contact section to be fully centered and prevent unintended left offset */
    .contact-section { margin-left: auto !important; margin-right: auto !important; left: 0 !important; right: 0 !important; transform: none !important; }
    /* Remove any accidental extra padding on inner grids */
    .contact-section .contact-grid { padding-left: 0 !important; padding-right: 0 !important; }
    /* Ensure the main content doesn't get pushed by wide background elements */
    .contact-section, .contact-section > * { max-width: 100%; overflow-x: hidden; }
  </style>
</MainLayout>
