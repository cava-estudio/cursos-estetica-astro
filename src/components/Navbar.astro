---
const pathname = Astro.url.pathname;

const navItems = [
  { label: "Inicio", href: "/", active: pathname === "/" },
  {
    label: "Sobre Nosotros",
    href: "/sobre-nosotros",
    active: pathname === "/sobre-nosotros",
  },
      {
        label: "Cursos",
        active: false,
        children: [
          {
            label: "Cursos Online Grabados",
            href: "/cursos/cursos-online-grabados",
            tone: "recorded",
          },
          {
            label: "Cursos Online Presenciales",
            href: "/cursos/cursos-online-presenciales",
            tone: "live",
          },
        ],
      },
  { label: "Noticias", href: "/noticias", active: pathname === "/noticias" },
  { label: "Contacto", href: "/contacto", active: pathname === "/contacto" },
];
---

<header class="section nav" aria-label="1 - nav-bar" data-nav-root>
  <a href="/" class="logo">
    <img src="/logo-pablo-ortiz.webp" alt="Pablo Ortiz Cursos de Estetica" />
  </a>

  <button
    class="nav-toggle"
    type="button"
    aria-label="Abrir menu"
    aria-expanded="false"
    aria-controls="main-menu"
    data-nav-toggle
  >
    <span class="nav-toggle-line"></span>
    <span class="nav-toggle-line"></span>
    <span class="nav-toggle-line"></span>
  </button>

  <nav class="menu" id="main-menu" aria-label="Navegacion principal" data-nav-menu>
    {navItems.map((item, index) => (
      item.children ? (
        <div class="menu-dropdown">
          <button
            class={item.active ? "menu-pill menu-button is-active" : "menu-pill menu-button"}
            type="button"
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls={`menu-dropdown-${index}`}
            data-dropdown-toggle
          >
            {item.label}
            <span class="caret" aria-hidden="true">▾</span>
          </button>
          <div class="dropdown-panel" id={`menu-dropdown-${index}`} data-dropdown-panel>
            {item.children.map((child) => (
              <a class={`dropdown-item ${child.tone === "live" ? "is-live" : "is-recorded"}`} href={child.href}>
                {child.label}
              </a>
            ))}
          </div>
        </div>
      ) : (
        <a class={item.active ? "menu-pill is-active" : "menu-pill"} href={item.href}>
          {item.label}
        </a>
      )
    ))}
    <!-- Mobile-only CTA: keeps the Aula Virtual link inside the toggled menu for small screens -->
    <a class="nav-cta menu-cta-mobile" href="https://aula.cursosdeestetica.cl/" data-nav-cta-mobile target="_blank" rel="noopener noreferrer">
      <span>Aula Virtual</span>
      <span class="nav-cta-icon" aria-hidden="true">↗</span>
    </a>
  </nav>

  <a class="nav-cta" href="https://aula.cursosdeestetica.cl/" data-nav-cta target="_blank" rel="noopener noreferrer">
    <span>Aula Virtual</span>
    <span class="nav-cta-icon" aria-hidden="true">↗</span>
  </a>
</header>

<script is:inline>
  const navRoots = document.querySelectorAll("[data-nav-root]");

  navRoots.forEach((root) => {
    const toggle = root.querySelector("[data-nav-toggle]");
    const menu = root.querySelector("[data-nav-menu]");

    // Make the navbar logic resilient if the desktop CTA is not present
    if (!toggle || !menu) return;

    const closeMenu = () => {
      root.classList.remove("is-open");
      toggle.setAttribute("aria-expanded", "false");
      root.querySelectorAll("[data-dropdown-toggle]").forEach((btn) => {
        btn.setAttribute("aria-expanded", "false");
        btn.closest(".menu-dropdown")?.classList.remove("is-expanded");
      });
    };

    const openMenu = () => {
      root.classList.add("is-open");
      toggle.setAttribute("aria-expanded", "true");
    };

    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      if (expanded) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    root.querySelectorAll("[data-dropdown-toggle]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const container = btn.closest(".menu-dropdown");
        if (!container) return;

        const willExpand = btn.getAttribute("aria-expanded") !== "true";

        root.querySelectorAll("[data-dropdown-toggle]").forEach((otherBtn) => {
          otherBtn.setAttribute("aria-expanded", "false");
          otherBtn.closest(".menu-dropdown")?.classList.remove("is-expanded");
        });

        if (willExpand) {
          btn.setAttribute("aria-expanded", "true");
          container.classList.add("is-expanded");
        }
      });
    });

    document.addEventListener("click", (event) => {
      if (!root.classList.contains("is-open")) return;
      if (!(event.target instanceof Node)) return;
      if (!root.contains(event.target)) {
        closeMenu();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeMenu();
      }
    });

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        closeMenu();
      });
    });
  });
</script>

<style is:inline>
  /* Make the mobile copy of the CTA visually similar to desktop but proportionate to other menu items */
  .menu-cta-mobile { display: none; }
  @media (max-width: 768px) {
    .menu-cta-mobile {
      display: inline-flex !important;
      min-width: 0 !important;
      width: auto; /* let content size it */
      max-width: 220px; /* restrict max width so it doesn't dominate */
      align-self: center;
      justify-content: center;
      padding: 8px 14px; /* balanced padding */
      box-sizing: border-box;
      order: 4;
      background: #f6f6f6;
      border: 2px solid #6f4ce4; /* slightly thicker border for presence */
      color: #6f4ce4;
      border-radius: 999px;
      gap: 8px;
      font-weight: 700;
      font-size: 0.92rem;
      min-height: 36px; /* compact */
    }
    .menu-cta-mobile .nav-cta-icon {
      width: 18px;
      height: 18px;
      font-size: 0.85rem;
      background: #e3964e;
      color: #fff;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
    }
  }
</style>
