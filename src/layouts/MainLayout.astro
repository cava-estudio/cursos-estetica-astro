---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const { title = "Cursos de Estetica | Antigravity" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="page">
      <div class="container">
        <Navbar />
        <slot />
        <Footer />
      </div>
    </main>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: "Erotique Trial";
    src: local("Erotique Trial"), local("Erotique Trial Bold");
    font-weight: 700;
    font-style: normal;
  }

  :root {
    --bg: #f4f3f2;
    --primary: #704fe6;
    --primary-2: #896af2;
    --text: #221b38;
    --muted: #665f81;
    --surface: #ffffff;
    --line: #e9e4f8;
    --radius-xl: 30px;
    --radius-lg: 22px;
    --radius-md: 18px;
    --shadow: 0 10px 30px rgba(43, 29, 95, 0.1);
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
    font-family: "Quicksand", sans-serif;
    color: var(--text);
    background:
      radial-gradient(circle at 15% 20%, rgba(112, 79, 230, 0.1), transparent 40%),
      radial-gradient(circle at 90% 8%, rgba(112, 79, 230, 0.16), transparent 32%),
      var(--bg);
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  .page {
    padding: 24px 16px 42px;
    display: flex;
    justify-content: center;
    width: 100%;
    max-width: 100%;
    overflow-x: clip;
  }

  .container {
    width: min(1320px, 100%);
    max-width: 100%;
    display: grid;
    gap: 14px;
  }

  .section {
    background: var(--surface);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow);
  }

  .nav {
    min-height: 132px;
    padding: 26px 24px 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    background: transparent;
    box-shadow: none;
    border-radius: 0;
    border-bottom: 1px solid #cfd6df;
  }

  .logo {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
  }

  .logo img {
    width: clamp(170px, 19vw, 300px);
    height: auto;
    display: block;
  }

  .menu {
    display: flex;
    flex-wrap: nowrap;
    justify-content: center;
    gap: 8px;
  }

  .nav-toggle {
    display: none;
    width: 46px;
    height: 46px;
    border-radius: 12px;
    border: 2px solid #6f4ce4;
    background: #f6f6f6;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
  }

  .nav-toggle-line {
    width: 20px;
    height: 2px;
    background: #6f4ce4;
    border-radius: 2px;
    display: block;
  }

  .menu-pill {
    text-decoration: none;
    color: #5f43cc;
    font-weight: 600;
    font-size: 1rem;
    line-height: 1;
    border: 2px solid #6f4ce4;
    border-radius: 999px;
    padding: 8px 18px 9px;
    background: rgba(255, 255, 255, 0.75);
    white-space: nowrap;
    transition: background 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;
  }

  .menu-pill.is-active {
    border-color: #6f4ce4;
    color: #ffffff;
    background: #6f4ce4;
    box-shadow: 0 6px 14px rgba(111, 76, 228, 0.22);
  }

  .menu-pill:hover {
    background: #f1ecff;
    color: #5237bb;
    box-shadow: 0 5px 12px rgba(111, 76, 228, 0.16);
  }

  .menu-button {
    font-family: inherit;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .menu-dropdown {
    position: relative;
  }

  .caret {
    font-size: 0.82em;
    transform: translateY(-1px);
  }

  .dropdown-panel {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    min-width: 280px;
    display: grid;
    gap: 6px;
    padding: 8px;
    border-radius: 14px;
    border: 1px solid #d9d9d9;
    background: #fff;
    box-shadow: 0 12px 24px rgba(20, 18, 29, 0.12);
    opacity: 0;
    visibility: hidden;
    transform: translateY(4px);
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s ease;
    z-index: 40;
  }

  .menu-dropdown:hover .dropdown-panel,
  .menu-dropdown:focus-within .dropdown-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-item {
    text-decoration: none;
    color: #2a2a2a;
    font-size: 0.92rem;
    font-weight: 600;
    padding: 10px 12px;
    border: 0;
    border-radius: 0;
    background: transparent;
    transition: transform 0.18s ease, opacity 0.18s ease;
  }

  .dropdown-item:hover {
    background: transparent;
    text-decoration: none;
    transform: translateX(4px);
    opacity: 0.9;
  }

  .dropdown-item:focus-visible {
    outline: none;
    text-decoration: none;
    transform: translateX(4px);
    opacity: 0.9;
  }

  .dropdown-item.is-recorded {
    color: #5a3fc2;
  }

  .dropdown-item.is-live {
    color: #b06117;
  }

  .nav-cta {
    text-decoration: none;
    border: 2px solid #6f4ce4;
    color: #6f4ce4;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    font-size: 2rem;
    line-height: 1;
    font-weight: 700;
    min-width: 286px;
    min-height: 74px;
    padding: 12px 26px;
    background: #f6f6f6;
  }

  .nav-cta-icon {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: #e3964e;
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.35rem;
    font-weight: 700;
  }

  .btn {
    border: 0;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 11px 20px;
    font-weight: 700;
    font-size: 0.94rem;
    transition: transform 0.2s ease;
    white-space: nowrap;
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn-primary {
    background: var(--primary);
    color: #fff;
  }

  .btn-soft {
    background: #eee9ff;
    color: var(--primary);
  }

  .btn-white {
    background: #fff;
    color: var(--primary);
  }

  .hero {
    min-height: clamp(430px, 45vw, 640px);
    position: relative;
    overflow: hidden;
    padding: 0;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    border-radius: 0 !important;
    box-shadow: none !important;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, #704fe6 10.19%, rgba(112, 79, 230, 0) 69.85%);
  }

  .hero-content {
    position: absolute;
    z-index: 2;
    left: clamp(18px, 10.3vw, 198px);
    top: clamp(28px, 7vw, 126px);
    max-width: 888px;
    padding: 0;
    color: #ffffff;
  }

  .hero-content h1 {
    margin: 0;
    line-height: 1;
    display: grid;
    gap: 12px;
    width: min(888px, 100%);
    text-shadow: 0 2px 10px rgba(18, 10, 48, 0.2);
    filter: drop-shadow(0 0 2px #00000099);
  }

  .hero-title-main {
    font-family: "Quicksand", sans-serif;
    font-size: clamp(2.2rem, 6vw, 90px);
    letter-spacing: 0;
    font-weight: 700;
    line-height: 0.9;
  }

  .hero-title-sub {
    font-family: "Quicksand", sans-serif;
    font-size: clamp(1.25rem, 3.2vw, 40px);
    line-height: 44px;
    font-weight: 400;
    letter-spacing: 0;
    width: min(888px, 100%);
    min-height: 44px;
    margin-top: 10px;
  }

  .hero-line {
    width: min(258px, 45vw);
    height: 46px;
    display: block;
    margin: 14px 0 12px clamp(24px, 20vw, 383px);
    overflow: visible;
  }

  .hero-line path {
    fill: none;
    stroke: #ce63ce;
    stroke-width: 12;
    stroke-linecap: round;
    stroke-linejoin: round;
    filter: drop-shadow(0 2px 4px rgba(39, 22, 82, 0.2));
  }

  .hero-content p {
    margin: 0;
    line-height: 35px;
    width: min(610px, 100%);
    min-height: 105px;
    font-size: clamp(1rem, 2.1vw, 28px);
    font-weight: 400;
    letter-spacing: 0;
    color: rgba(255, 255, 255, 0.95);
    text-shadow: 0 2px 10px rgba(18, 10, 48, 0.2);
  }

  .hero-tags {
    margin-top: clamp(14px, 2.6vw, 36px);
    max-width: 520px;
    display: flex;
    flex-wrap: wrap;
    gap: 9px 10px;
  }

  .hero-tag {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    border: 2px solid rgba(255, 255, 255, 0.86);
    border-radius: 999px;
    padding: 4px 16px 5px;
    font-size: clamp(0.92rem, 1.25vw, 1.08rem);
    color: #fff;
    background: rgba(95, 76, 173, 0.15);
    text-decoration: none;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .hero-tag.is-dark {
    background: #2a263780;
  }

  .hero-tag:hover {
    transform: translateY(-1px);
    background: rgba(95, 76, 173, 0.36);
  }

  .hero-tag.is-dark:hover {
    background: rgba(42, 38, 55, 0.72);
  }

  .hero-corner-logo {
    position: absolute;
    top: 0;
    right: clamp(16px, 7vw, 138px);
    width: 239px;
    height: 203px;
    z-index: 3;
    background: #fff;
    border-bottom-right-radius: 10px;
    border-bottom-left-radius: 10px;
    display: grid;
    place-items: center;
    box-shadow: 0 8px 16px rgba(15, 11, 32, 0.14);
  }

  .hero-corner-logo img {
    width: 88%;
    height: auto;
    display: block;
  }

  .eyebrow {
    margin: 0;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 700;
    font-size: 0.72rem;
  }

  .banner {
    min-height: 108px;
    padding: 18px 26px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .banner h3 {
    margin: 8px 0 0;
    line-height: 1.18;
    font-size: clamp(1.05rem, 1.95vw, 1.65rem);
  }

  .banner-one {
    min-height: 55px;
    height: 55px;
    padding: 0 24px;
    background: #2a2637;
    color: #ffffff;
    border-radius: 0;
    box-shadow: none;
    border: 0;
    justify-content: center;
    width: 100vw;
    min-width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
  }

  .banner-track {
    width: min(1926px, 100%);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
  }

  .banner-track span {
    font-family: "Quicksand", sans-serif;
    font-weight: 600;
    font-size: 18px;
    line-height: 24px;
    letter-spacing: 0;
    text-align: center;
    white-space: nowrap;
    color: #ffffff;
  }

  .banner-two .eyebrow {
    color: #f6efff;
  }

  .vendidos {
    min-height: 760px;
    background: transparent;
    box-shadow: none;
    border-radius: 0;
    padding: 54px 0 18px;
  }

  .vendidos-heading {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 26px;
  }

  .vendidos-mark {
    width: 84px;
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle, #cbc6e8 58%, transparent 60%) center/19px 19px;
  }

  .vendidos h2 {
    margin: 0;
    font-size: clamp(2rem, 3vw, 3.65rem);
    font-weight: 500;
    color: #15131f;
  }

  .cards {
    margin-top: 18px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .cards-featured {
    margin-top: 0;
    grid-template-columns: 1.62fr 1fr;
    gap: 20px;
    padding: 20px;
    border-radius: 24px;
    background: #d9d3ea;
  }

  .featured-card {
    position: relative;
    min-height: 520px;
    overflow: hidden;
    border-radius: 22px;
    border: 3px solid #6d51df;
    background: #1f1a2d;
  }

  .featured-card img {
    position: absolute;
    inset: -2%;
    width: 104%;
    height: 104%;
    object-fit: cover;
    transform: scale(1.04);
    transform-origin: center;
    backface-visibility: hidden;
  }

  .featured-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(35, 27, 58, 0.22), rgba(35, 27, 58, 0.42));
  }

  .featured-pill {
    position: absolute;
    top: 16px;
    left: 16px;
    z-index: 2;
    min-width: 224px;
    border-radius: 999px;
    border: 2px solid #ffffff;
    background: linear-gradient(90deg, #6f4fe4, #7e66ea);
    color: #fff;
    text-align: center;
    font-size: 20px;
    line-height: 1;
    font-weight: 600;
    padding: 8px 14px 10px;
  }

  .featured-content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: grid;
    place-content: center;
    justify-items: center;
    gap: 8px;
    color: #fff;
    text-shadow: 0 2px 10px rgba(9, 7, 18, 0.34);
  }

  .featured-content h3 {
    margin: 0;
    font-size: clamp(2rem, 2.7vw, 3rem);
    font-weight: 500;
  }

  .featured-link {
    text-decoration: none;
    color: #fff;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: clamp(1.35rem, 1.5vw, 1.8rem);
    font-weight: 500;
  }

  .featured-link-icon {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: #fff;
    color: #6f4fe4;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    font-weight: 700;
  }

  .featured-seal {
    position: absolute;
    right: 22px;
    bottom: 16px;
    z-index: 2;
    width: 104px;
    aspect-ratio: 1;
    border-radius: 50%;
    display: grid;
    place-content: center;
    text-align: center;
    color: #fff;
    line-height: 1;
    padding: 10px;
    border: 1px solid rgba(255, 255, 255, 0.42);
    background: rgba(255, 255, 255, 0.22);
    backdrop-filter: blur(8px) saturate(132%);
    box-shadow: 0 10px 20px rgba(11, 8, 22, 0.24);
  }

  .seal-icon {
    width: 24px;
    height: 24px;
    border-radius: 6px;
    border: 2px solid rgba(255, 255, 255, 0.95);
    background:
      linear-gradient(#fff, #fff) 5px 5px / 12px 2px no-repeat,
      linear-gradient(#fff, #fff) 5px 10px / 12px 2px no-repeat,
      linear-gradient(#fff, #fff) 5px 15px / 12px 2px no-repeat;
    margin-inline: auto;
  }

  .featured-seal span:last-child {
    font-size: 12px;
    font-weight: 600;
    margin-top: 4px;
  }

  .featured-card:not(.is-wide) .featured-content h3 {
    font-size: clamp(1.8rem, 2.2vw, 2.55rem);
  }

  .banner-two {
    position: relative;
    overflow: hidden;
    min-height: 480.25px;
    padding: 34px clamp(20px, 3vw, 48px);
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 28px;
    border: 1px solid #cec4ee;
    border-radius: 0;
    box-shadow: none;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    background: linear-gradient(110deg, #6a48dc 0%, #7f61ea 56%, #9a84f6 100%);
    color: #fff;
  }

  .banner-two::before {
    content: "";
    position: absolute;
    inset: auto auto -120px -120px;
    width: 380px;
    height: 380px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.22), rgba(255, 255, 255, 0));
    pointer-events: none;
  }

  .banner-two-content {
    max-width: 820px;
    position: relative;
    z-index: 1;
  }

  .banner-two h3 {
    margin: 12px 0 0;
    font-size: clamp(1.5rem, 2.35vw, 2.35rem);
    line-height: 1.26;
    font-weight: 600;
  }

  .banner-two-logo {
    position: relative;
    z-index: 1;
    width: clamp(190px, 21vw, 290px);
    display: grid;
    place-items: center;
  }

  .banner-two-logo img {
    width: 100%;
    height: auto;
    display: block;
  }

  .cursos {
    min-height: 1180px;
    padding: 92px 28px 38px;
    position: relative;
    overflow: hidden;
    background: transparent;
    box-shadow: none;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
  }

  .cursos-header {
    position: relative;
    z-index: 2;
    display: grid;
    justify-items: center;
    text-align: center;
    gap: 22px;
  }

  .cursos-header h2 {
    margin: 0;
    font-family: "Quicksand", sans-serif;
    font-weight: 600;
    font-size: clamp(2.4rem, 4.6vw, 60px);
    line-height: 24px;
    color: #2a2637;
  }

  .cursos-header p {
    margin: 0;
    width: min(1120px, 100%);
    max-width: none;
    font-weight: 600;
    font-size: 22px;
    line-height: 30px;
    color: #606060;
  }

  .cursos-line {
    width: 264px;
    height: 41px;
    display: block;
    margin-bottom: 14px;
  }

  .cursos-line path {
    fill: none;
    stroke: #dad5e9;
    stroke-width: 11;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .cursos-dot {
    position: absolute;
    z-index: 1;
    width: 66.34px;
    height: 59.72px;
    border-radius: 50%;
    background: #dec8fe;
    opacity: 1;
    pointer-events: none;
  }

  .cursos-dot-left {
    top: 84px;
    left: 24px;
  }

  .cursos-dot-right {
    top: 264px;
    right: 28px;
  }

  .cursos-ornaments {
    position: absolute;
    right: -150px;
    bottom: -60px;
    width: 709.66px;
    height: 548px;
    opacity: 0.35;
    pointer-events: none;
    z-index: 0;
  }

  .ornament {
    position: absolute;
    left: 0;
    border-radius: 100px;
    display: block;
  }

  .ornament-1 {
    top: 0;
    width: 645.27px;
    height: 100.7px;
    background: #dec8fe;
  }

  .ornament-2 {
    top: 149.33px;
    width: 709.66px;
    height: 100.01px;
    background: #bc9ceb;
  }

  .ornament-4 {
    top: 297.98px;
    width: 704.87px;
    height: 100.7px;
    background: #a276e2;
  }

  .ornament-3 {
    top: 447.31px;
    width: 617.87px;
    height: 100.7px;
    background: #8d50e5;
  }

  .grid-cursos {
    position: relative;
    z-index: 1;
    margin-top: 46px;
    width: min(1260px, 100%);
    margin-inline: auto;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 28px 24px;
  }

  .curso-item {
    min-height: 796px;
    border: 1px solid #ffffff;
    border-radius: 15px;
    padding: 20px;
    background: #ffffff;
    box-shadow: 0 6px 8.9px -2px rgba(0, 0, 0, 0.25);
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 20px;
    align-content: start;
  }

  .curso-media {
    position: relative;
    width: 100%;
    height: 532px;
    border: 0;
    border-radius: 15px;
    overflow: hidden;
    background: transparent;
    -webkit-mask-image: -webkit-radial-gradient(white, black);
  }

  .curso-item img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: scale(1.02);
    transform-origin: center;
  }

  .curso-offer {
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 129px;
    min-height: 38px;
    border-radius: 200px;
    border: 2px solid #6f6f76;
    background: rgba(42, 38, 55, 0.84);
    color: #ffffff;
